.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.detail-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.plate-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 30rpx;
  border-bottom: 1px solid #eee;
  margin-bottom: 30rpx;
}

.plate-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.plate-color {
  font-size: 28rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.plate-color.blue { background-color: #e6f7ff; color: #1890ff; }
.plate-color.black { background-color: #f5f5f5; color: #333; }
.plate-color.white { background-color: #fff; color: #333; border: 1px solid #ddd; }
.plate-color.yellow { background-color: #fff7e6; color: #fa8c16; }
.plate-color.green { background-color: #f6ffed; color: #52c41a; }

.info-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  font-size: 28rpx;
  color: #999;
}

.value {
  font-size: 28rpx;
  color: #333;
}

.value.fee {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.status-badge {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.status-badge.in {
  background-color: #f6ffed;
  color: #52c41a;
}

.status-badge.out {
  background-color: #f5f5f5;
  color: #999;
}

.image-section {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1px solid #eee;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
}

.capture-image {
  width: 100%;
  border-radius: 8rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}