.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.refresh-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 8rpx;
}

.tabs {
  display: flex;
  background-color: #fff;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #1890ff;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #1890ff;
  border-radius: 2rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 160rpx;
}

.record-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.plate-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.plate-color {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-right: 20rpx;
}

.plate-color.blue { background-color: #e6f7ff; color: #1890ff; }
.plate-color.black { background-color: #f5f5f5; color: #333; }
.plate-color.white { background-color: #fff; color: #333; border: 1px solid #ddd; }
.plate-color.yellow { background-color: #fff7e6; color: #fa8c16; }
.plate-color.green { background-color: #f6ffed; color: #52c41a; }

.status-badge {
  margin-left: auto;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-badge.in {
  background-color: #f6ffed;
  color: #52c41a;
}

.status-badge.out {
  background-color: #f5f5f5;
  color: #999;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  font-size: 26rpx;
}

.label {
  color: #999;
  width: 180rpx;
}

.value {
  color: #333;
}

.value.fee {
  color: #ff4d4f;
  font-weight: bold;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.gate-control {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 30rpx;
  padding: 30rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.gate-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  color: #fff;
}

.gate-btn.open {
  background-color: #52c41a;
}

.gate-btn.close {
  background-color: #ff4d4f;
}